{
    "name": "feed",
    "version": "1.0.0",
    "private": true,
    "license": "MIT",
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "bootstrap": "npm ci",
        "dev:admin": "npm --workspace @feed/admin run dev",
        "dev:scanner": "npm --workspace @feed/scanner run dev",
        "dev": "npm-run-all -p dev:admin dev:scanner",
        "build": "npm-run-all -s build:admin build:scanner",
        "build:admin": "npm --workspace @feed/admin run build",
        "build:scanner": "npm --workspace @feed/scanner run build",
        "preview:admin": "npm --workspace @feed/admin run preview",
        "preview:scanner": "npm --workspace @feed/scanner run preview",
        "tc": "tsc -b",
        "tc:watch": "tsc -b -w",
        "lint:ts": "eslint \"packages/**/*.{ts,tsx}\"",
        "lint-fix:ts": "eslint \"packages/**/*.{ts,tsx}\" --fix",
        "lint:css": "stylelint \"packages/**/*.{css,scss,less}\"",
        "lint-fix:css": "stylelint --fix \"packages/**/*.{css,scss,less}\"",
        "format": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,css,scss,less,md}\"",
        "format:write": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css,scss,less,md}\"",
        "lint": "npm-run-all -s lint:* format tc",
        "lint-fix": "npm-run-all -s lint-fix:* format:write",
        "madge": "npx madge packages",
        "stat": "tokei",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@rolldown/plugin-babel": "^0.2.3",
        "@stylistic/stylelint-plugin": "^5.1.0",
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "cross-env": "^10.0.0",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.0",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.3",
        "stylelint": "^17.9.1",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "vite": "^8.0.8",
        "vite-plugin-pwa": "^1.3.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json,md}": "prettier --write",
        "*.{css,scss,less}": "stylelint --fix"
    }
}
