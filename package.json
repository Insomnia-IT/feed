{
    "name": "feed",
    "version": "1.0.0",
    "private": true,
    "license": "MIT",
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "bootstrap": "npm ci",
        "dev:admin": "npm --workspace @feed/admin run dev",
        "dev:scanner": "npm --workspace @feed/scanner run dev",
        "dev": "node scripts/run-npm-parallel.mjs dev:admin dev:scanner",
        "build": "npm run build:admin && npm run build:scanner",
        "build:admin": "npm --workspace @feed/admin run build",
        "build:scanner": "npm --workspace @feed/scanner run build",
        "preview:admin": "npm --workspace @feed/admin run preview",
        "preview:scanner": "npm --workspace @feed/scanner run preview",
        "tc": "tsc -b",
        "tc:watch": "tsc -b -w",
        "lint:ts": "eslint \"packages/**/*.{ts,tsx}\"",
        "lint-fix:ts": "eslint \"packages/**/*.{ts,tsx}\" --fix",
        "lint:css": "stylelint \"packages/**/*.{css,scss,less}\"",
        "lint-fix:css": "stylelint --fix \"packages/**/*.{css,scss,less}\"",
        "format": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,css,scss,less,md}\"",
        "format:write": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css,scss,less,md}\"",
        "lint": "npm run lint:ts && npm run lint:css && npm run format && npm run tc",
        "lint-fix": "npm run lint-fix:ts && npm run lint-fix:css && npm run format:write",
        "madge": "npx madge packages",
        "stat": "tokei",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@rolldown/plugin-babel": "^0.2.3",
        "@types/node": "^26.1.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^10.6.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "prettier": "^3.9.4",
        "stylelint": "^17.14.0",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1",
        "vite": "^8.1.3",
        "vite-plugin-pwa": "^1.3.0"
    }
}
