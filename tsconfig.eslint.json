{
    "compilerOptions": {
        "noEmit": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2020",
        "module": "ESNext",
        "jsx": "react-jsx",
        "lib": ["ES2022", "DOM", "DOM.Iterable"]
    },
    "include": [
        "packages/admin/src/**/*",
        "packages/scanner/src/**/*",
        "packages/shared/src/**/*",
        "packages/shared/vitest.config.ts"
    ],
    "exclude": ["**/dist", "**/build", "**/node_modules"]
}
