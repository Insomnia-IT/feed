{
    "name": "@feed/admin",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "cross-env VITE_NEW_API_URL_ENV='http://localhost:8000/feedapi/v1' vite",
        "dev:stage": "cross-env VITE_NEW_API_URL_ENV='https://feedapp-dev.insomniafest.ru/feedapi/v1' vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "lint:js": "eslint .",
        "lint-fix:js": "eslint . --fix",
        "lint:css": "stylelint ./src/**/*.css",
        "lint-fix:css": "stylelint --fix ./src/**/*.css",
        "tc": "tsc --noemit --emitDeclarationOnly false",
        "preview": "vite preview",
        "test": "vitest",
        "test:run": "vitest run"
    },
    "dependencies": {
        "@ant-design/icons": "^5.6.1",
        "@refinedev/antd": "^6.0.3",
        "@refinedev/core": "^5.0.12",
        "@refinedev/react-router": "^2.0.3",
        "@tanstack/react-query": "^5.96.2",
        "accesscontrol": "^2.2.1",
        "antd": "^5.29.3",
        "axios": "^1.15.0",
        "classnames": "^2.5.1",
        "dayjs": "^1.11.13",
        "js-cookie": "^3.0.5",
        "onscan.js": "^1.5.2",
        "qr-scanner": "^1.4.1",
        "quill": "^2.0.3",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-router": "^7.14.0",
        "recharts": "^3.8.1",
        "ulid": "^3.0.2",
        "uuid": "^13.0.0"
